# Doxyfile — Gauge Reader

PROJECT_NAME           = "Gauge Reader"
PROJECT_NUMBER         = 0.1.0
PROJECT_BRIEF          = "Qt6 + OpenCV gauge reader with ellipse detection and needle tracking"

# Input
INPUT                  = inc src knowledge.md workflow.md
FILE_PATTERNS          = *.h *.cpp *.md
RECURSIVE              = YES
EXCLUDE_PATTERNS       = build/* .cache/* .git/*

# Output
OUTPUT_DIRECTORY       = docs
GENERATE_HTML          = YES
GENERATE_LATEX         = NO
HTML_OUTPUT            = html

# Source browsing
SOURCE_BROWSER         = YES
INLINE_SOURCES         = NO
STRIP_CODE_COMMENTS    = YES
REFERENCED_BY_RELATION = YES
REFERENCES_RELATION    = YES

# Extraction
EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = NO
EXTRACT_STATIC         = YES
EXTRACT_LOCAL_CLASSES  = YES

# Diagrams
HAVE_DOT               = NO
CLASS_GRAPH            = NO

# Warnings
QUIET                  = YES
WARNINGS               = YES
WARN_IF_UNDOCUMENTED   = NO

# Preprocessing
ENABLE_PREPROCESSING   = YES
MACRO_EXPANSION        = YES
EXPAND_ONLY_PREDEF     = YES
PREDEFINED             = Q_OBJECT="" \
                         Q_DISABLE_COPY_MOVE(x)="" \
                         Q_DECLARE_METATYPE(x)="" \
                         override=""

# Formatting
FULL_PATH_NAMES        = NO
SHORT_NAMES            = YES
JAVADOC_AUTOBRIEF      = YES
MULTILINE_CPP_IS_BRIEF = YES
INHERIT_DOCS           = YES

# Index
ALPHABETICAL_INDEX     = YES
